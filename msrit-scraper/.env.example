# ── Portal ────────────────────────────────────────────────────────────────────
PORTAL_URL=https://staff.msrit.edu
LOGIN_TIMEOUT=15
SCRAPE_TIMEOUT=10
HEADLESS=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=msrit_attendance
DB_USER=your_postgres_username
DB_PASSWORD=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate once with:  python3 scripts/generate_fernet_key.py
# NEVER regenerate after teachers have been added — it will break all stored passwords.
FERNET_KEY=your_fernet_key_here

# ── Chrome ────────────────────────────────────────────────────────────────────
# Leave empty to auto-download via webdriver-manager
CHROME_DRIVER_PATH=

# ── Backend API ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ATTENDANCE_THRESHOLD=75.0

# ── Notification service ──────────────────────────────────────────────────────
NOTIFICATION_SERVICE_URL=http://localhost:8001

# ── SMTP (Gmail App Password — NOT your regular Gmail password) ───────────────
# Setup: Google Account → Security → 2FA → App Passwords → generate one
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16_char_app_password
ALERT_SENDER=you@gmail.com

# ── Student email CSV ─────────────────────────────────────────────────────────
# Path to the USN→Email CSV file, synced at backend startup
# Format:  USN,Email
EMAILS_CSV_PATH=emails.csv
