# ── SMTP (Gmail App Password — NOT your regular Gmail password) ───────────────
# Setup: Google Account → Security → 2FA → App Passwords → generate one
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16_char_app_password
ALERT_SENDER=you@gmail.com

# ── Database (same PostgreSQL DB as scraper + backend) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=msrit_attendance
DB_USER=your_postgres_username
DB_PASSWORD=

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_PORT=8001
