# ══════════════════════════════════════════════════════════════════════════════
#  MSRIT Attendance System — root .gitignore
#  Covers: msrit-scraper/  notification-service/  frontend/
# ══════════════════════════════════════════════════════════════════════════════


# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Student PII — real email addresses ───────────────────────────────────────
# Keep emails.csv out of version control (contains student personal data).
# Each deployment populates it locally.
emails.csv


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
MANIFEST
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / pyright
.mypy_cache/
.dmypy.json
.pyright/


# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
build/

# Vite
frontend/.vite/
frontend/dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ── Chrome / Selenium ─────────────────────────────────────────────────────────
# webdriver-manager download cache
.wdm/
chromedriver
geckodriver


# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.swp
*.swo
*~


# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.sqlite3
*.db
